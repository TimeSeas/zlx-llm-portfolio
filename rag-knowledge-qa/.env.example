# ========== Ollama 本地模型配置 ==========
# Ollama 服务地址（默认本地）
OLLAMA_BASE_URL=http://localhost:11434
# 对话模型名（运行前需 ollama pull <model>）
LLM_MODEL=qwen2.5:7b
# 嵌入模型名（运行前需 ollama pull <model>）
EMBEDDING_MODEL=bge-large-zh-v1.5

# ========== 向量库配置 ==========
# Chroma 持久化目录（相对于项目根目录）
CHROMA_PERSIST_DIR=data/vector_store
# 默认集合名
CHROMA_COLLECTION_NAME=knowledge_base

# ========== 文本分割配置 ==========
# 每个 chunk 的最大字符数
CHUNK_SIZE=500
# chunk 之间的重叠字符数
CHUNK_OVERLAP=50

# ========== 检索配置 ==========
# 检索时返回的最相似文档数
TOP_K=4
# 相似度阈值（低于此值的结果会被过滤）
SIMILARITY_THRESHOLD=0.3

# ========== 日志级别 ==========
LOG_LEVEL=INFO
